<clickhouse>
  <!-- Disable most system logs to save storage -->
  <!-- ENGINE = Null keeps tables queryable but discards all writes to disk -->
  <query_thread_log>
    <engine>ENGINE = Null</engine>
  </query_thread_log>
  <part_log>
    <engine>ENGINE = Null</engine>
  </part_log>
  <trace_log>
    <engine>ENGINE = Null</engine>
  </trace_log>
  <metric_log>
    <engine>ENGINE = Null</engine>
  </metric_log>
  <asynchronous_metric_log>
    <engine>ENGINE = Null</engine>
  </asynchronous_metric_log>
  <text_log>
    <engine>ENGINE = Null</engine>
  </text_log>
  <session_log>
    <engine>ENGINE = Null</engine>
  </session_log>
  <opentelemetry_span_log>
    <engine>ENGINE = Null</engine>
  </opentelemetry_span_log>
  <processors_profile_log>
    <engine>ENGINE = Null</engine>
  </processors_profile_log>
  <asynchronous_insert_log>
    <engine>ENGINE = Null</engine>
  </asynchronous_insert_log>
  <error_log>
    <engine>ENGINE = Null</engine>
  </error_log>

  <!-- Keep query_log but with 7-day TTL for debugging -->
  <query_log>
    <database>system</database>
    <table>query_log</table>
    <partition_by>toYYYYMM(event_date)</partition_by>
    <ttl>event_date + INTERVAL 7 DAY</ttl>
    <flush_interval_milliseconds>7500</flush_interval_milliseconds>
  </query_log>
</clickhouse>
