# Public URL where users reach Git AI (set your real domain)
WEB_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
WORKER_PUBLIC_BASE_URL=http://localhost:3000

# Enterprise license key (required)
LICENSE_KEY=

# Security secrets (auto-generated by scripts/init-env.sh if empty)
BETTER_AUTH_SECRET=
WORKER_JWT_SECRET=
WEB_INTERNAL_API_KEY=
SCM_WEBHOOK_SECRET_KEY=

# Optional email settings
EMAIL_PROVIDER=disabled
EMAIL_FROM=notifications@example.com
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/data/worker-storage
# If STORAGE_BACKEND=aws:
# WORKER_STORAGE_BUCKET_NAME=
# If STORAGE_BACKEND=azure:
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=git-ai-worker-storage
# If STORAGE_BACKEND=gcp:
# GCP_STORAGE_BUCKET=   # or set WORKER_STORAGE_BUCKET_NAME

# Batch execution mode
# Recommended for Docker Compose self-hosting:
ANALYZE_BATCH_PROVIDER=local
# If using aws:
# ANALYZE_BATCH_PROVIDER=aws
# ANALYZE_BATCH_AWS_JOB_QUEUE=
# ANALYZE_BATCH_AWS_JOB_DEFINITION=

# Queue configuration
BULLMQ_PREFIX={git-ai}
BULLMQ_DASHBOARD_ENABLED=true
BULLMQ_DASHBOARD_PORT=3001

# Org sync schedule (optional)
# ORG_SYNC_INTERVAL_SECONDS=86400  # default: 86400 (24 h). Set to e.g. 3600 for hourly.
# ORG_SYNC_ANCHOR_HOUR_UTC=0       # default: 0 (midnight UTC). UTC hour 0-23 for first-run anchor.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# Redis/Valkey
REDIS_URL=redis://redis:6379

# ClickHouse
CLICKHOUSE_HTTP_URL=http://clickhouse:8123
CLICKHOUSE_USER=gitai
CLICKHOUSE_PASSWORD=gitai
CLICKHOUSE_DATABASE=default
